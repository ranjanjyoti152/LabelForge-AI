# Copy this file to .env and adjust values for your environment.
SAM3_CHECKPOINT_PATH=./weights/sam3.pt
SAM3_DEVICE=cuda
SAM3_SCORE_THRESHOLD=0.5
SAM3_MAX_DETECTIONS=25
SAM3_RTSP_TIMEOUT=5
SAM3_FRAME_SKIP=1
SAM3_MAX_FRAMES=3
SAM3_CONCEPTS_PATH=
SAM3_EXTRA_CONCEPTS=
SAM3_USE_DEFAULT_CONCEPTS=true
SAM3_MAX_CONCEPTS_PER_REQUEST=160
SAM3_HF_TOKEN=
SAM3_LABELSTUDIO_FROM_NAME=label
SAM3_LABELSTUDIO_TO_NAME=image
SAM3_LABELSTUDIO_MODEL_VERSION=sam3-v0.1
SAM3_LABELSTUDIO_API_BASE=
SAM3_LABELSTUDIO_API_TOKEN=

# SAM3 Server URL used by tools/prepare_yolo_dataset.py
SAM3_SERVER_URL=http://localhost:8000

# Optional Cosmos Predict2.5 synthetic data generation.
# Clone https://github.com/nvidia-cosmos/cosmos-predict2.5 next to this repo,
# then run the "cosmos" Docker Compose service when weak classes need samples.
HF_TOKEN=
COSMOS_PREDICT25_REPO=../cosmos-predict2.5
COSMOS_PREDICT25_IMAGE=cosmos-predict-2.5
COSMOS_COMPOSE_SERVICE=cosmos
COSMOS_CUDA_NAME=cu128
COSMOS_CACHE_DIR=${HOME}/.cache
COSMOS_MODEL=2B/distilled
COSMOS_DEFAULT_INFERENCE_TYPE=text2world
COSMOS_FRAMES_PER_VIDEO=12
COSMOS_SYNTHETIC_MAX_RATIO=0.35
DATASET_MIN_SAMPLES_PER_CLASS=300

# Optional LM Studio prompt generation for project-specific Cosmos prompts.
LM_STUDIO_API_BASE=http://localhost:1234/v1
LM_STUDIO_MODEL=
LM_STUDIO_API_KEY=lm-studio
